# warp-rust 配置文件示例
# 所有字段都可以通过环境变量覆盖，例如 WARP_RUST_SERVER__BIND=0.0.0.0:1080
# （`__` 分隔表段名和字段名）

[server]
# SOCKS5 监听地址。个人本机使用绑 127.0.0.1，需要对外暴露时改成 0.0.0.0
bind = "127.0.0.1:1080"

# 启用用户名/密码鉴权时取消注释；整个表段省略 = 无鉴权
# [server.auth]
# username = "me"
# password = "..."

[logging]
# tracing 的 env-filter 过滤器；环境变量 RUST_LOG 会优先于此处的值
level = "warn,warp_rust=info,wireguard_netstack=warn"
# 输出格式：pretty | compact | json
format = "pretty"

[warp]
# 凭据与身份池目录
data_dir = "./data"
# 注册时上报给 Cloudflare 的设备型号字符串（仪表盘展示用）
device_model = "warp-rust"
# 可选的 WARP+ 许可证 key（用真 1.1.1.1 客户端购买的才有效，referral 来的无效）
# license_key = "xxxxxxxx-xxxxxxxx-xxxxxxxx"
# 周期重新拉取一次 WireGuard 配置。设 "0s" 关闭
refresh_interval = "24h"
# 两次重注册之间的最小冷却（防风暴；Cloudflare 注册接口对源 IP 有限流）
register_cooldown = "10m"
# WireGuard 接口 MTU。默认 1420（标准 WireGuard / wireproxy 常用值）；
# 若底层路径 PMTU 不足导致卡顿或丢包，可回退到 1280
mtu = 1420
# smoltcp TCP socket 单向 buffer。实际每条 TCP 连接约占 2 × 该值。
# 64KB 会把 15-50ms RTT 的单连接吞吐卡在几十 Mbps；1MB 更适合大流量代理。
tcp_buffer_size = 1048576

[health]
# 健康探针节奏（每多少秒拨号一次 1.1.1.1:443，确认隧道通畅）
interval = "30s"
# 单次探针超时
timeout = "8s"

[recovery]
# 自愈阶梯：连续失败几次触发对应级别的恢复动作
reconnect_after        = 1   # 1 次失败 → 用同一配置重连
rebuild_config_after   = 3   # 3 次失败 → 重新向 Cloudflare 拉取一份新配置
reregister_after       = 5   # 5 次失败 → 丢弃 account.json，重新注册账号
rotate_identity_after  = 10  # 10 次失败 → 从 data/identities/ 取下一个身份替换
# 每次重连前的指数退避
backoff_min = "500ms"
backoff_max = "30s"

[metrics]
# Prometheus /metrics 端点；enabled=false 时不会监听端口
enabled = true
bind = "127.0.0.1:9090"

[hot_reload]
# 监听本配置文件的变化。v1 行为：变化时仅重新解析校验，把结果写入日志；
# 非平凡字段（监听地址、日志级别等）仍需重启才能生效
enabled = true

[limits]
# v0.1.1 起内置 DoS 防护，所有字段都可调
max_concurrent_connections = 1024   # 同时在飞 SOCKS5 连接上限；满即拒
handshake_timeout = "10s"           # SOCKS5 握手 + read_command 总超时
idle_timeout = "300s"               # 双向 relay 的 idle 超时
relay_buffer_size = 262144          # TCP relay buffer；对齐 wireproxy 的 256KB buffer pool
auth_fail_sleep = "1s"              # 鉴权失败后强制延迟，防暴破

[dns]
# Domain ATYP 的 DNS 解析策略：
#   "system" — 走宿主 OS DNS（默认，最快最兼容，但 DNS 查询不走隧道、泄漏域名）
#   "tunnel" — 通过 WARP 隧道内 UDP 拨 servers 查 A 记录（更隐私，多一跳 RTT）
mode = "system"
servers = ["1.1.1.1:53", "1.0.0.1:53"]   # mode = "tunnel" 时使用
timeout = "3s"
cache_ttl = "60s"                  # 解析结果缓存 TTL；命中跳过 DNS 查询
